# 阿里云访问密钥
ALIBABA_CLOUD_ACCESS_KEY_ID=your_access_key_id
ALIBABA_CLOUD_ACCESS_KEY_SECRET=your_access_key_secret

# 域名配置
DOMAIN_NAME=your_domain.com

# DNS记录配置
LAN_SUBDOMAIN=lan          # 局域网IP子域名，例如：lan.your_domain.com
WAN_SUBDOMAIN=wan          # 公网IP子域名，例如：wan.your_domain.com

# ECS配置
SECURITY_GROUP_ID=sg-xxxxx        # 安全组ID
REGION_ID=cn-hangzhou             # 地域ID，默认为杭州
SECURITY_DESCRIPTION=description  # 安全组描述

# 更新配置
UPDATE_INTERVAL=10                 # 更新间隔（分钟），默认为10分钟
ENABLE_DNS_RECORD_UPDATE=true      # 是否启用DNS记录更新
ENABLE_SECURITY_GROUP_UPDATE=true  # 是否启用安全组IP更新
